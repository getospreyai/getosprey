# Neon / Vercel Postgres connection string.
# On Vercel: added automatically when you attach a Neon database (Storage tab).
# Locally: copy this file to .env.local and paste your Neon *pooled* connection string.
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require"

# Auth.js (next-auth v5) session signing secret.
# Generate with: openssl rand -base64 32
# On Vercel: set in Project Settings > Environment Variables.
AUTH_SECRET=""

# Telegram bot token from @BotFather (same bot as local dev: @OspreyAlphaBot).
# Used by /api/telegram (send/receive) and /api/cron/scan (deliver verdicts).
TELEGRAM_BOT_TOKEN=""

# Shared secret verified against the `x-telegram-bot-api-secret-token` header
# on inbound webhook calls, so only Telegram can hit /api/telegram.
# Generate with: openssl rand -hex 24
TELEGRAM_WEBHOOK_SECRET=""

# Shared secret verified against the `Authorization: Bearer <value>` header
# on /api/cron/scan, so only the Vercel Cron Job can trigger a scan.
# Generate with: openssl rand -hex 24
CRON_SECRET=""

# RentCast API key (https://developers.rentcast.io/) — powers the daily
# listings pull and per-listing rent estimates in /api/cron/scan.
RENTCAST_API_KEY=""

# Anthropic API key. Optional: without it, the Telegram bot still handles
# A / P / S / HELP keywords via the deterministic fast-path, but plain-English
# replies and grounded Q&A are disabled.
ANTHROPIC_API_KEY=""

# Market the daily scan pulls listings for. Optional — defaults to Las Vegas, NV.
OSPREY_CITY=""
OSPREY_STATE=""
